# Fresh 535 Environment Variables
# Copy this file to .env.local and fill in the values

# =============================================================================
# DATABASE
# =============================================================================
# SQLite file path (local dev) or LibSQL/Turso connection URL (production)
# Local: file:prisma/dev.db
# Turso: libsql://<your-db>.turso.io?authToken=<your-token>
DATABASE_URL="file:prisma/dev.db"

# =============================================================================
# ADMIN AUTHENTICATION
# =============================================================================
# Email address for the admin account
ADMIN_EMAIL="admin@fresh535.org"

# Plain-text password for the admin account (use a strong password in production)
ADMIN_PASSWORD=""

# Secret key used to sign admin session tokens (use a long random string)
# Generate: openssl rand -hex 32
ADMIN_SECRET=""

# =============================================================================
# ANALYTICS (optional)
# =============================================================================
# Google Analytics 4 measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"
